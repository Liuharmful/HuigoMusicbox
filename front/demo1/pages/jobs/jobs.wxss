/* 加载/错误/空状态样式保持不变 */
.loading-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 60rpx 20rpx;
    gap: 16rpx;
  }
  
  .loading-spinner {
    width: 36rpx;
    height: 36rpx;
    border: 4rpx solid #eee;
    border-top-color: #4285f4;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }
  
  .loading-text {
    color: #666;
    font-size: 28rpx;
  }
  
  .error-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 60rpx 40rpx;
    margin: 30rpx;
    background-color: #fff8f8;
    border-radius: 16rpx;
    gap: 20rpx;
  }
  
  .error-icon {
    font-size: 60rpx;
    color: #ff4d4f;
  }
  
  .error-text {
    color: #d93025;
    font-size: 30rpx;
    text-align: center;
  }
  
  .error-retry {
    margin-top: 10rpx;
    padding: 12rpx 36rpx;
    background-color: #ff4d4f;
    color: white;
    font-size: 28rpx;
    border-radius: 8rpx;
    border: none;
  }
  
  .empty-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 80rpx 20rpx;
    gap: 20rpx;
  }
  
  .empty-icon {
    font-size: 80rpx;
    color: #ddd;
  }
  
  .empty-text {
    color: #999;
    font-size: 32rpx;
  }
  
  .empty-subtext {
    color: #ccc;
    font-size: 26rpx;
  }
  
  /* 列表样式 */
  .job-list {
    padding: 20rpx;
    background-color: #fafafa;
  }
  
  .list-header {
    padding: 10rpx 0 20rpx;
    border-bottom: 1rpx solid #f0f0f0;
    margin-bottom: 20rpx;
  }
  
  .list-title {
    color: #333;
    font-size: 30rpx;
    font-weight: 500;
  }
  
  /* 职位项样式 */
  .job-item {
    padding: 30rpx;
    margin-bottom: 24rpx;
    background-color: white;
    border-radius: 16rpx;
    box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.03);
    transition: all 0.2s ease;
  }
  
  .job-item-hover {
    transform: translateY(-2rpx);
    box-shadow: 0 6rpx 15rpx rgba(0, 0, 0, 0.05);
  }
  
  .job-title {
    color: #1a1a1a;
    font-size: 34rpx;
    font-weight: 600;
    margin-bottom: 15rpx;
    line-height: 1.3;
  }
  
  .job-company {
    color: #666;
    font-size: 28rpx;
    padding-top: 10rpx;
    border-top: 1rpx dashed #f0f0f0;
  }
  
  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }