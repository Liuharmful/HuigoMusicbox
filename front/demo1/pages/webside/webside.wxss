/* pages/webside/webside.wxss */
/* pages/timetable/timetable.wxss */
/* 通用样式 */
.container {
    display: flex;
    flex-direction: column;
    height: 100%;
    background-color: #f5f5f5;
  }
  
  /* 登录界面样式（仅保留这部分） */
  .login-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40rpx;
  }
  
  .logo {
    margin-bottom: 60rpx;
  }
  
  .logo image {
    width: 200rpx;
    height: 200rpx;
  }
  
  .login-form {
    width: 100%;
    max-width: 500rpx;
  }
  
  .form-group {
    margin-bottom: 30rpx;
  }
  
  .form-group label {
    display: block;
    margin-bottom: 10rpx;
    font-size: 28rpx;
    color: #333;
  }
  
  .form-group input {
    width: 100%;
    padding: 20rpx;
    border: 1px solid #ddd;
    border-radius: 10rpx;
    font-size: 28rpx;
  }
  
  .captcha-container {
    display: flex;
    gap: 20rpx;
  }
  
  .captcha-container input {
    flex: 1;
  }
  
  .captcha-container image {
    width: 200rpx;
    height: 80rpx;
    border-radius: 10rpx;
  }
  
  .login-btn {
    width: 100%;
    padding: 20rpx;
    background-color: #1e88e5;
    color: white;
    border: none;
    border-radius: 10rpx;
    font-size: 32rpx;
    font-weight: bold;
    margin-top: 20rpx;
  }
  
  .tips {
    margin-top: 20rpx;
    text-align: center;
    font-size: 24rpx;
    color: #666;
  }